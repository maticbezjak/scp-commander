{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SCP Commander",
  "version": "0.1.0",
  "identifier": "net.manto.scpcommander",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SCP Commander",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
